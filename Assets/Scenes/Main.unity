  id: 1
  title: Assertiveness
  conversationText: 'Marcus: Can you cover my shift Saturday?

    Priya: I might
    have plans already.

    Marcus: I told my boss you''d do it.

    Priya: You
    told them without asking me?

    Marcus: You never have anything going on.'
  assertiveness: 0.9
  empathy: 0.2
  emotionalRegulation: 0.4
  socialConfidence: 0.5
  prosocialIntent: 0.1
  cameraTarget: {fileID: 756686522721743681}
