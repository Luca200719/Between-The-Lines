  m_EditorClassIdentifier: Assembly-CSharp::Dialogue
  audioClips:
  - {fileID: 8300000, guid: c9dbe27461967384d9316b55e97ff79e, type: 3}
  - {fileID: 8300000, guid: 4ccf54f6a6d53dd4bb228121c1b5f841, type: 3}
  - {fileID: 8300000, guid: e79b967293632d84aa7fe7837c9cf783, type: 3}
  - {fileID: 8300000, guid: afb74866402592948945fd9f881dfe9b, type: 3}
  - {fileID: 8300000, guid: 357e4201c6a7f82489e8ff7bb5954a2f, type: 3}
  - {fileID: 8300000, guid: 224842326c4c6f84a96be5872799468f, type: 3}
  - {fileID: 8300000, guid: 89d705389c2bc6743a523d32eefe18eb, type: 3}
  - {fileID: 8300000, guid: 62f631765cc5e114bb9fafb17f521774, type: 3}
  - {fileID: 8300000, guid: eed33021d85123e47b4b829c5551b9f0, type: 3}
  - {fileID: 8300000, guid: d81d46f40a6b0004c8c2eefdbdfe2bda, type: 3}
  - {fileID: 8300000, guid: d5f8b8193f5a35341a21913e426072d0, type: 3}
  - {fileID: 8300000, guid: f64500dd35ee7e24db73d094752c3766, type: 3}
  - {fileID: 8300000, guid: 49d0e63f5e46bb5408970463b4087d3c, type: 3}
  - {fileID: 8300000, guid: becdbf9d2da28ac43be3776cb2d29b0e, type: 3}
  - {fileID: 8300000, guid: 8420870b291f5b24da2507956486adc7, type: 3}
  - {fileID: 8300000, guid: 5190b8baf5b15604e84bb443df5a8ff4, type: 3}
  - {fileID: 8300000, guid: bb56fe883a706fb44974aae70311b3b7, type: 3}
  audioClipA: {fileID: 0}
  audioClipB: {fileID: 0}
  lines:
  - speaker: 0
    text: I signed you up to present tomorrow.
  - speaker: 1
    text: I wasn't prepared for that at all.
  - speaker: 0
    text: You're the best at explaining things.
  - speaker: 1
    text: You still should have asked me first.
  - speaker: 0
    text: I figured you wouldn't mind.
  question: Why is it hard to push back when someone means well?
